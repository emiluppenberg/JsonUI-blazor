@using System.Threading.Tasks
<div class="transition-column node-col" style="top: @(RowOffset* RowHeightPx)px;">

  @foreach (var kvp in CurrentNode.KeyValues)
  {
    <button @key="kvp" class="transition-kvp button-kvp">
      <span class="span-key">@kvp.Key</span>
      <span class="span-value">@kvp.Value</span>
    </button>
  }

  @foreach (var child in CurrentNode.Children)
  {
    <button @key="child" class="transition-node @ButtonNodeClass(child)"
      @onclick="() => ToggleNode(child, CurrentNode.Children.IndexOf(child))">
      <span class="@SpanNodeNameClass(child)">@child.Name</span>
      <span class="@SpanNodeTypeClass(child)">@child.Type</span>
    </button>
  }

</div>

@if (NextNode is not null && NextNode.IsExpanded)
{
  <JNodeView CurrentNode="NextNode" RowOffset="NextRowOffset" OnNodeToggled="PassOnNodeToggled" />
}

@code {
  const int RowHeightPx = 22;

  [Parameter]
  public int RowOffset { get; set; }
  [Parameter]
  public JNode CurrentNode { get; set; } = default!;
  [Parameter]
  public EventCallback<JNode> OnNodeToggled { get; set; }

  public int NextRowOffset { get; set; }

  public JNode? NextNode { get; set; } = null;

  async Task ToggleNode(JNode node, int nodeIndex)
  {
    NextNode = node;
    NextRowOffset = 1 + RowOffset + CurrentNode.KeyValues.Count + nodeIndex;

    await OnNodeToggled.InvokeAsync(node);
  }

  async Task PassOnNodeToggled(JNode newNode) => await OnNodeToggled.InvokeAsync(newNode);

  private string ButtonNodeClass(JNode node) => node.IsExpanded ? "button-node-expanded" : "button-node";

  private string SpanNodeNameClass(JNode node) => node.IsExpanded ? "span-node-name-expanded" : "span-key";

  private string SpanNodeTypeClass(JNode node) => node.IsExpanded ? "span-node-type-expanded" : "span-value";
}