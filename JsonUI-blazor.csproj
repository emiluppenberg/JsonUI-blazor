<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="JsonUI-blazor.Client\JsonUI-blazor.Client.csproj" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.Server" Version="10.0.1" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="JsonUI-blazor.Client\**\*.cs" />
    <Content Remove="JsonUI-blazor.Client\**\*" />
    <EmbeddedResource Remove="JsonUI-blazor.Client\**\*" />
    <None Remove="JsonUI-blazor.Client\**\*" />
    <RazorComponent Remove="JsonUI-blazor.Client\**\*.razor" />
  </ItemGroup>

</Project>
