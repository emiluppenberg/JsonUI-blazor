{
  "devDependencies": {
    "tailwindcss": "^4.1.18"
  },
  "scripts": {
    "tailwind:build": "tailwindcss -c ./tailwind.config.js -i ./wwwroot/css/tailwind.css -o ./wwwroot/css/app.css --minify",
    "tailwind:watch": "tailwindcss -c ./tailwind.config.js -i ./wwwroot/css/tailwind.css -o ./wwwroot/css/app.css --watch"
  }
}
