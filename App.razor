    <script type="application/ld+json">
        {
        "@@context": "https://schema.org",
        "@@type": "SoftwareApplication",
        "name": "PickJSON",
        "applicationCategory": "DeveloperTool",
        "operatingSystem": "Web",
        "url": "https://www.pickjson.com/",
