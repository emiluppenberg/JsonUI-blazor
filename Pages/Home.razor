@page "/"
@using JsonUI_blazor.Components
@inject HttpClient httpClient
@inject JsonBuilder jsonBuilder

<PageTitle>Home</PageTitle>
<div>
  <div>
    <input type="text" @bind="url" class="input-base" />
    <button class="button-base" @onclick="GetRequest">Get</button>
    <button class="button-base" @onclick="LoadJson">Load</button>
  </div>

  <div class="node-container">
    @if (jNodes?.Count > 0)
    {
      <JNodeView CurrentNode="jNodes[0]" OnNodeToggled="HandleNodeToggled" />
    }
  </div>
</div>

@code {
  string url = "https://lldev.thespacedevs.com/2.3.0/launches/eea43b3f-eddc-437a-ada5-8e23286f1eef/";
  List<JNode> jNodes = new();

  async Task LoadJson()
  {
    var json = await httpClient.GetStringAsync("j.json");
    jNodes = jsonBuilder.CreateFromJson(json)!;
  }

  async Task GetRequest()
  {
    HttpResponseMessage? response = await httpClient.GetAsync(url);
    response.EnsureSuccessStatusCode();

    var jsonContent = await response.Content.ReadAsStringAsync();
    var result = jsonBuilder.CreateFromJson(jsonContent);
    jNodes = result is not null ? result : jNodes;
  }

  void HandleNodeToggled(JNode newNode)
  {
    var toggleTo = !newNode.IsExpanded;
    jNodes.ForEach(n => n.IsExpanded = false);

    newNode.IsExpanded = toggleTo;

    if (newNode.Parent is not null)
    {
      var iteratingNode = newNode;

      do
      {
        iteratingNode = iteratingNode.Parent;
        iteratingNode.IsExpanded = true;
      }
      while (iteratingNode.Parent is not null);
    }
  }
}