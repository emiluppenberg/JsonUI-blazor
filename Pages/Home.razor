@page "/"
@using JsonUI_blazor.Components
@using static General
@inject HttpClient httpClient

<PageTitle>Home</PageTitle>

<div class="menu">

  <div class="json-menu">

    <div class="json-option">
      <button class="transition gen @(LoadingUrl ? "button-base-active" : "button-base")"
        @onclick="async () => await ToggleLoadUrl()">Load from
        URL</button>
    </div>

    <div class="json-option">
      <button class="transition-gen @(LoadingText ? "button-base-active" : "button-base")"
        @onclick="async () => await ToggleLoadText()">Load from
        TEXT</button>
    </div>

    <div class="json-option relative">
      <div class="transition-input load-menu @(LoadingText ? "scale-x-100" : "scale-x-0")">
        <textarea class="load-textarea" @bind="Json"></textarea>
        <div class="load-buttons-row">
          <button class="button-load" @onclick="() => LoadJson(Json)">OK</button>
          <button class="button-load" @onclick="() => { LoadingText = false; }">Cancel</button>
        </div>
      </div>

      <div class="transition-input load-menu @(LoadingUrl ? "scale-x-100 h-auto" : "scale-x-0 h-auto")">
        <input type="text" @bind="Url" class="load-input" />
        <div class="load-buttons-row">
          <button class="button-load" @onclick="async () => await FetchRequest()">OK</button>
          <button class="button-load" @onclick="() => { LoadingUrl = false; }">Cancel</button>
        </div>
      </div>
    </div>

  </div>

  <div class="code-menu">

    <div class="code-option">
      <label class="code-option-label">Collections</label>
      <select class="code-option-select" @bind="DefaultCollection">
        @foreach (var o in General.GetCollectionOptions())
        {
          <option value="@o">@o.ToString()</option>
        }
      </select>
    </div>

    <div class="code-option">
      <label class="code-option-label">Pascalcase</label>
      <button class="button-base transition-gen" @onclick="() => { UsePascalCase = !UsePascalCase; }">Set</button>
    </div>

    <div class="code-option">
      <label class="code-option-label">Nullable</label>
      <button class="button-base transition-gen" @onclick="() => { DefaultNullable = !DefaultNullable; }">Set</button>
    </div>

  </div>
</div>

<div class="app-container">
  <div class="node-container" id="node-container">
    @if (JNodes?.Count > 0)
    {
      <JNodeView CurrentNode="JNodes[0]" ContainerHeight="NodeContainerHeight" OnNodeToggled="HandleNodeToggled"
        OnKvpSelected="HandleKvpSelected" OnRenderCode="HandleRenderCode" />
    }
  </div>

  <pre class="code">@RenderCode</pre>
</div>

@code {
  public string Url { get; set; } = "https://lldev.thespacedevs.com/2.3.0/launches/797939fd-480c-4e5a-8c0a-53b36b2695fe/";
  public string RenderCode { get; set; } = "";
  public string Json { get; set; } = "";
  public bool LoadingText { get; set; }
  public bool LoadingUrl { get; set; }
  public int NodeContainerHeight;
  public List<JNode> JNodes { get; set; } = new();

  private CSharpOptions csOptions;
  public bool UsePascalCase
  {
    get => csOptions.UsePascalCase;
    set
    {
      csOptions.UsePascalCase = value;
      HandleRenderCode();
    }
  }

  private CollectionsCSharp defaultCollection;
  public CollectionsCSharp DefaultCollection
  {
    get => defaultCollection;
    set
    {
      defaultCollection = value;
      JNodes.ForEach(x => x.SetNodeCollectionAs(value));
      JNodes.ForEach(x => x.SetKvpsCollectionAs(value));
      HandleRenderCode();
    }
  }

  private bool defaultNullable;
  public bool DefaultNullable
  {
    get => defaultNullable;
    set
    {
      defaultNullable = value;
      JNodes.ForEach(x => x.SetNullable(value));
      HandleRenderCode();
    }
  }

  protected override async Task OnInitializedAsync()
  {
    var json = await httpClient.GetStringAsync("j.json");
    LoadJson(json);
  }

  void LoadJson(string json)
  {
    JNodes = JNodeBuilder.CreateFromJson(json, csOptions)!;
    JNodes.ForEach(x => x.SetKvpsCollectionAs(DefaultCollection));
    JNodes.ForEach(x => x.SetNodeCollectionAs(DefaultCollection));
    NodeContainerHeight = (JNodes[0].KeyValues.Count + JNodes[0].Children.Count) * General.RowHeightPx;
    LoadingText = false;
    LoadingUrl = false;
  }

  async Task ToggleLoadUrl()
  {
    LoadingUrl = !LoadingUrl;
    LoadingText = false;
    await InvokeAsync(StateHasChanged);
  }

  async Task ToggleLoadText()
  {
    LoadingText = !LoadingText;
    LoadingUrl = false;
    await InvokeAsync(StateHasChanged);
  }

  async Task FetchRequest()
  {
    try
    {
      HttpResponseMessage? response = await httpClient.GetAsync(Url);
      response.EnsureSuccessStatusCode();

      var json = await response.Content.ReadAsStringAsync();
      LoadJson(json);
    }
    catch (Exception ex)
    {
      Console.WriteLine($"// BASE - {ex.GetBaseException().Message} // INNER - {ex.InnerException?.Message} // SOURCE - {ex.Source} // STACKTRACE - {ex.StackTrace} // TARGETSITE - {ex.TargetSite}");
    }
  }

  async Task HandleNodeToggled(JNode newNode)
  {
    var toggleTo = !newNode.IsExpanded;
    JNodes.ForEach(n => n.IsExpanded = false);

    newNode.IsExpanded = toggleTo;
    NodeContainerHeight = (newNode.KeyValues.Count + newNode.Children.Count) * General.RowHeightPx;

    if (newNode.Parent is not null)
    {
      var iteratingNode = newNode;

      do
      {
        iteratingNode = iteratingNode.Parent;
        iteratingNode.IsExpanded = true;
        NodeContainerHeight += (iteratingNode.KeyValues.Count + iteratingNode.Children.Count) * General.RowHeightPx;
      }
      while (iteratingNode.Parent is not null);
    }

    await InvokeAsync(StateHasChanged);
  }

  async Task HandleKvpSelected(KvpSelectedArgs args)
  {
    args.node.TotalNestedSelected += args.selected ? 1 : -1;

    var iteratingNode = args.node;

    while (iteratingNode.Parent is not null)
    {
      iteratingNode = iteratingNode.Parent;
      iteratingNode.TotalNestedSelected += args.selected ? 1 : -1;
    }

    await InvokeAsync(StateHasChanged);
  }

  void HandleRenderCode()
  {
    RenderCode = JNodeBuilder.JNodesToCSharp(JNodes, csOptions);
  }
}