@inject IJSRuntime JS

@page "/privacy"

<PageTitle>Privacy</PageTitle>

<div class="w-full px-5 md:px-50 py-12 text-white overflow-y-scroll">

  <div class="flex space-x-5 mb-6 items-center">
    <h1 class="text-3xl font-light">Privacy Policy</h1>
    <p class="text-sm text-slate-300">Last updated: 16 January 2026</p>
  </div>

  <p class="mb-6 leading-relaxed">
    This Privacy Policy describes how <strong>PickJSON</strong> (“we”, “us”, or “our”)
    processes information when you visit
    <a href="https://www.pickjson.com" class="text-blue-300 underline hover:text-blue-500" target="_blank"
      rel="noopener noreferrer">
      https://www.pickjson.com
    </a>
    (the “Website”).
  </p>

  <h2 class="mt-8 mb-3 text-xl font-light">1. Information We Collect</h2>

  <p class="mb-4 leading-relaxed">
    The PickJSON tool runs entirely in the browser. We do not require user accounts and we do not store or process
    user-submitted JSON data on any servers.
  </p>

  <p class="mb-4 leading-relaxed">
    When you visit this Website, certain information may be processed automatically by third-party services, in
    particular advertising providers. This may include:
  </p>

  <ul class="mb-4 list-disc space-y-1 pl-6">
    <li>IP address</li>
    <li>Browser type and version</li>
    <li>Device information</li>
    <li>Pages visited and interaction data</li>
  </ul>

  <p class="mb-6 leading-relaxed">
    This information is processed through a combination of cookies, browser local storage, and network requests.
  </p>

  <h2 class="mt-8 mb-3 text-xl font-light">2. Cookies and Similar Technologies</h2>

  <p class="mb-4 leading-relaxed">
    The Website uses cookies and similar technologies solely for the purpose of displaying advertisements.
  </p>

  <p class="mb-4 leading-relaxed">
    We do not use cookies for first-party analytics or tracking.
  </p>

  <p class="mb-4 leading-relaxed">
    You may control or delete cookies through your browser settings.
  </p>

  <h2 class="mt-8 mb-3 text-xl font-light">3. Google AdSense</h2>

  <p class="mb-4 leading-relaxed">
    We use <strong>Google AdSense</strong>, a third-party advertising service provided by Google Inc.
  </p>

  <p class="mb-4 leading-relaxed">
    Google may use cookies and similar technologies to serve ads based on a user's visits to this Website or other
    websites.
  </p>

  <p class="mb-4 leading-relaxed">
    You may opt out of personalized advertising by visiting:
    <br />
    <a href="https://adssettings.google.com" class="text-blue-300 underline hover:text-blue-500" target="_blank"
      rel="noopener noreferrer">
      https://adssettings.google.com
    </a>
  </p>

  <p class="mb-6 leading-relaxed">
    More information about how Google uses data:
    <br />
    <a href="https://policies.google.com/technologies/ads" class="text-blue-300 underline hover:text-blue-500"
      target="_blank" rel="noopener noreferrer">
      https://policies.google.com/technologies/ads
    </a>
  </p>

  <h2 class="mt-8 mb-3 text-xl font-light">4. Third-Party Vendors</h2>

  <p class="mb-6 leading-relaxed">
    Third-party vendors, including Google, may use cookies or similar technologies
    to serve ads or perform measurements related to advertising delivery. We do not control how these third parties use
    their cookies.
  </p>

  <h2 class="mt-8 mb-3 text-xl font-light">5. Legal Basis for Processing (EU/EEA)</h2>

  <ul class="mb-4 list-disc space-y-1 pl-6">
    <li><strong>Consent:</strong> for advertising cookies and similar technologies</li>
    <li><strong>Legitimate interests:</strong> for basic technical operation of the Website</li>
  </ul>

  <p class="mb-6 leading-relaxed">
    You may withdraw your consent at any time by adjusting your browser settings or using the cookie controls
    provided below.</p>

  <select class="select-base" @bind="CookieConsent" @bind:after="async () => await SetCookieConsent()">
    <option selected disabled>Cookie consent</option>
    <option value="accepted">Accept</option>
    <option value="rejected">Reject</option>
  </select>

  <h2 class="mt-8 mb-3 text-xl font-light">6. Data Protection Rights (GDPR)</h2>

  <ul class="mb-4 list-disc space-y-1 pl-6">
    <li>Access your personal data</li>
    <li>Request correction or deletion</li>
    <li>Restrict or object to processing</li>
    <li>Lodge a complaint with a supervisory authority</li>
  </ul>

  <h2 class="mt-8 mb-3 text-xl font-light">7. Changes to This Privacy Policy</h2>

  <p class="mb-6 leading-relaxed">
    We may update this Privacy Policy from time to time.
    Changes will be posted on this page with an updated revision date.
  </p>

  <h2 class="mt-8 mb-3 text-xl font-light">8. Contact Information</h2>

  <p>
    <strong>Email:</strong>
    <a href="mailto:pickjson@outlook.com" class="text-blue-300 underline hover:text-blue-500">
      pickjson@outlook.com
    </a>
  </p>
</div>

@code {
  public string? CookieConsent { get; set; }

  async Task SetCookieConsent()
  {
    if (CookieConsent is not null)
    {
      await JS.InvokeVoidAsync("localStorage.setItem", General.StorageKey, CookieConsent);
    }
  }
}